#!/bin/bash

URL="$1"

if [ -z "$URL" ]; then
  echo "Usage: tgb_latest <blog_url>"
  exit 1
fi

BASE=~/Workspace/openclaw_ops
TMP_DIR=$(mktemp -d /tmp/tgb_job_XXXXXX)

echo "==[1/4] Fetch latest main post=="
python3 $BASE/scripts/tgb/fetch_latest_main.py --url "$URL" --out "$TMP_DIR"

echo "==[2/4] Download images=="
python3 $BASE/scripts/tgb/download_images.py --job "$TMP_DIR"

echo "==[3/4] OCR + Parse + Classify + Analyze=="
python3 $BASE/scripts/tgb/run_tgb_job.py --job "$TMP_DIR"

echo "==[4/4] Move to permanent jobs directory=="
DEST="$BASE/jobs/tgb/$(basename $TMP_DIR)"
mkdir -p $BASE/jobs/tgb
mv "$TMP_DIR" "$DEST"

echo "==============================="
echo "DONE."
echo "Job stored at:"
echo "$DEST"
